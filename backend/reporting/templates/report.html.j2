<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="Vietnam Pharma Equity Research Report — {{ ticker }}">
  <title>{{ ticker }} — Báo cáo nghiên cứu cổ phiếu | {{ report_date }}</title>
  <style>
{{ css }}
  </style>
  <!-- Recommendation colour classes (not in base CSS) -->
  <style>
.recommendation-buy        { background: #e6f4ea; border-left: 4px solid #34a853; }
.recommendation-hold       { background: #fef7e0; border-left: 4px solid #fbbc04; }
.recommendation-sell       { background: #fce8e6; border-left: 4px solid #ea4335; }
.recommendation-accumulate { background: #e8f0fe; border-left: 4px solid #1a73e8; }
.recommendation-reduce     { background: #fff3e0; border-left: 4px solid #ff9800; }
.recommendation-review     { background: #f5f5f5; border-left: 4px solid #9e9e9e; }
/* Override recommendation-card base when a colour modifier is present */
.recommendation-card.recommendation-buy,
.recommendation-card.recommendation-hold,
.recommendation-card.recommendation-sell,
.recommendation-card.recommendation-accumulate,
.recommendation-card.recommendation-reduce,
.recommendation-card.recommendation-review {
  border-top: none;
  border-bottom: none;
  padding: 10px 16px;
  margin: 12px 0;
  border-radius: 4px;
  font-size: 14px;
}
  </style>
</head>
<body>

  <!-- ── Rating → CSS class mapping ───────────────────────── -->
  {% set _rating_class_map = {
    "BUY":          "recommendation-buy",
    "ACCUMULATE":   "recommendation-accumulate",
    "HOLD":         "recommendation-hold",
    "REDUCE":       "recommendation-reduce",
    "SELL":         "recommendation-sell",
    "UNDER_REVIEW": "recommendation-review"
  } %}
  {% set rec_class = _rating_class_map.get((rating or "") | upper, "recommendation-review") %}

  <!-- ── Internal notice banner ──────────────────────────── -->
  {% if status and ('DRAFT' in status or 'NEEDS_REVIEW' in status or 'PENDING' in status) %}
  <div class="draft-banner">
    BÁO CÁO NHÁP (DRAFT) — {{ status }} | Không xuất bản chính thức | Assumptions chưa được phê duyệt
  </div>
  {% endif %}

  <!-- ── Recommendation summary banner
       Suppressed when the first section (snapshot cover page) already contains
       an embedded recommendation hero — avoids a near-blank banner page.
       Also suppressed in review/audit mode. -->
  {% if not is_review and not suppress_rec_banner %}
  <div class="recommendation-card {{ rec_class }}">
    <strong>{{ ticker }}</strong> — {{ company_name | default(ticker) }}
    &nbsp;|&nbsp;
    <strong>{{ recommendation_label | default(rating) }}</strong>
    &nbsp;|&nbsp;
    Giá mục tiêu: <strong>{{ target_price_fmt | default("—") }}</strong>
    &nbsp;|&nbsp;
    Upside: <strong>{{ upside_fmt | default("—") }}</strong>
    &nbsp;|&nbsp;
    {{ report_date }}
  </div>
  {% endif %}

  <!-- ── Report Sections ───────────────────────────────── -->
  {% for section in sections %}
  <div class="report-section{% if section.chapter_break | default(false) %} chapter-break{% endif %}" id="section-{{ section.page }}">
    {% if not loop.first %}
    <div class="acbs-page-header">
      <span>{% if is_review %}{{ ticker }} — Bản rà soát nội bộ{% else %}Cập nhật {{ ticker }} - {{ recommendation_label or rating }}{% endif %}</span>
      <span>Ngày {{ report_date }}</span>
    </div>
    {% endif %}
    {{ section.html | safe }}
  </div>
  {% endfor %}

  <!-- ── Report Footer ─────────────────────────────────── -->
  <div class="report-footer">
    Vietnam Pharma Equity Research | {{ ticker }} | {{ report_date }} |
    Tài liệu này chỉ dành cho mục đích nghiên cứu học thuật.
    {% if status and 'DRAFT' in status %}| DRAFT — Chưa được phê duyệt{% endif %}
  </div>

  <!-- ── Running footer — every printed page (Chrome headless) ── -->
  <!-- Hidden on screen; position:fixed makes it appear on all print pages.
       WeasyPrint uses @page margin boxes in the CSS instead. -->
  <div class="print-running-footer" aria-hidden="true">
    Vietnam Pharma Equity Research &nbsp;·&nbsp; {{ ticker }} &nbsp;·&nbsp; {{ report_date }}
  </div>

</body>
</html>
