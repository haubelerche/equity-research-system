# Canonical runtime/object storage. Keep directory contract, ignore payloads.
storage/sources/
storage/runs/
storage/exports/
storage/archive/



# Font binaries — provisioned locally via scripts/setup_fonts.py
assets/fonts/*.ttf
assets/fonts/*.otf

# Run-scoped artifacts (production output — not source)
artifacts/runs/
artifacts/reports_pdf/.chrome-profile-*/
artifacts/dev/

# Runtime storage-migration dumps — reproducible audit output, not source
audits/storage_migrations/

# Reproducible runtime output — never source (reports, logs, dumps, debug traces)
artifacts/

data/
# Frontend source lives under a dir literally named "data" — keep it tracked
!frontend/src/data/
!frontend/src/data/**

# Frontend source component dirs match gitignored names — keep them tracked
!frontend/src/components/reports/
!frontend/src/components/reports/**

storage/debug/


