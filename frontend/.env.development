# Local dev: leave VITE_API_BASE empty so requests are same-origin and are
# forwarded to the backend (http://localhost:8000) by the Vite dev proxy in
# vite.config.ts. Do NOT set this to the Railway *dashboard* URL
# (railway.com/project/...) — that is the web console, not your API, and will
# be blocked by CORS. To target a deployed backend, use its service URL, e.g.
# https://<service>.up.railway.app
VITE_API_BASE=
