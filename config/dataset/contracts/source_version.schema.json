{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maer.local/schemas/source_version.schema.json",
  "title": "SourceVersion",
  "type": "object",
  "required": [
    "source_id",
    "source_uri",
    "source_type",
    "published_at",
    "ingested_at",
    "checksum",
    "connector_version"
  ],
  "properties": {
    "source_id": { "type": "string", "minLength": 1 },
    "source_uri": { "type": "string", "format": "uri" },
    "source_type": {
      "type": "string",
      "enum": [
        "financial_statement",
        "market_reference",
        "catalyst_tender",
        "catalyst_policy",
        "catalyst_regulatory",
        "catalyst_company_news"
      ]
    },
    "effective_date": { "type": ["string", "null"], "format": "date" },
    "published_at": { "type": "string", "format": "date-time" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "checksum": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "connector_version": { "type": "string", "minLength": 1 },
    "ingestion_run_id": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
