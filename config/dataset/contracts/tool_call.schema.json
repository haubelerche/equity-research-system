{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ToolCall",
  "type": "object",
  "properties": {
    "run_id": { "type": "string" },
    "step_id": { "type": "string" },
    "agent_role": {
      "type": "string",
      "enum": ["SupervisorAgent", "DataRetrievalAgent", "FinancialAnalystAgent", "ValuationAgent", "ReportWriterCriticAgent"]
    },
    "tool_name": { "type": "string" },
    "arguments_json": { "type": "object" },
    "expected_output_schema": { "type": "string" },
    "timeout_policy": { "type": "string" },
    "retry_policy": { "type": "string" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "run_id",
    "step_id",
    "agent_role",
    "tool_name",
    "arguments_json",
    "expected_output_schema",
    "timeout_policy",
    "retry_policy",
    "created_at"
  ],
  "additionalProperties": false
}

