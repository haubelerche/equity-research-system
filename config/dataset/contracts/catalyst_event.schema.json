{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maer.local/schemas/catalyst_event.schema.json",
  "title": "CatalystEvent",
  "type": "object",
  "required": [
    "event_id",
    "event_type",
    "title",
    "occurred_at",
    "company_ticker",
    "source_url",
    "source_version_id",
    "confidence",
    "validation_status",
    "ingested_at"
  ],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "type": "string",
      "enum": [
        "tender_notice",
        "tender_award",
        "bhyt_policy_change",
        "regulatory_approval",
        "regulatory_recall",
        "company_announcement",
        "industry_news"
      ]
    },
    "title": { "type": "string", "minLength": 5 },
    "summary": { "type": ["string", "null"] },
    "occurred_at": { "type": "string", "format": "date-time" },
    "effective_date": { "type": ["string", "null"], "format": "date" },
    "company_ticker": { "type": "string", "minLength": 2, "maxLength": 10 },
    "materiality_hint": { "type": ["string", "null"], "enum": ["low", "medium", "high", null] },
    "source_url": { "type": "string", "format": "uri" },
    "source_version_id": { "type": "string", "minLength": 1 },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "validation_status": {
      "type": "string",
      "enum": ["accepted", "accepted_with_warning", "needs_review", "rejected"]
    },
    "ingested_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
