{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maer.local/schemas/citation.schema.json",
  "title": "Citation",
  "type": "object",
  "required": [
    "citation_id",
    "run_id",
    "claim_id",
    "claim_type",
    "chunk_id",
    "source_version_id",
    "grounding_status",
    "confidence"
  ],
  "properties": {
    "citation_id": { "type": "string", "minLength": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "claim_id": { "type": "string", "minLength": 1 },
    "claim_type": { "type": "string", "enum": ["quantitative", "qualitative"] },
    "chunk_id": { "type": "string", "minLength": 1 },
    "source_version_id": { "type": "string", "minLength": 1 },
    "page": { "type": ["integer", "null"], "minimum": 1 },
    "excerpt": { "type": ["string", "null"] },
    "grounding_status": { "type": "string", "enum": ["pass", "fail", "manual_review"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
  },
  "additionalProperties": false
}
