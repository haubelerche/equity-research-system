{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CanonicalFinancialFactBenchmarkRow",
  "type": "object",
  "required": [
    "ticker",
    "fiscal_year",
    "period",
    "statement_type",
    "canonical_key",
    "value",
    "unit",
    "currency",
    "source_type",
    "source_uri",
    "source_title",
    "provider",
    "confidence",
    "validation_status"
  ],
  "properties": {
    "ticker": {
      "type": "string",
      "pattern": "^[A-Z0-9]{2,4}$"
    },
    "fiscal_year": {
      "type": "integer",
      "minimum": 2015,
      "maximum": 2030
    },
    "period": {
      "type": "string",
      "pattern": "^[0-9]{4}(FY|Q[1-4]|YTD)$"
    },
    "statement_type": {
      "type": "string",
      "enum": [
        "income_statement",
        "balance_sheet",
        "cash_flow",
        "capital_structure"
      ]
    },
    "canonical_key": {
      "type": "string",
      "minLength": 3
    },
    "raw_label": {
      "type": [
        "string",
        "null"
      ]
    },
    "value": {
      "type": [
        "number",
        "null"
      ]
    },
    "unit": {
      "type": "string",
      "enum": [
        "vnd_bn",
        "vnd",
        "shares",
        "ratio",
        "percent",
        "unknown"
      ]
    },
    "currency": {
      "type": "string",
      "enum": [
        "VND",
        "N/A"
      ]
    },
    "source_type": {
      "type": "string"
    },
    "source_uri": {
      "type": "string",
      "minLength": 1
    },
    "source_title": {
      "type": "string",
      "minLength": 1
    },
    "provider": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "validation_status": {
      "type": "string",
      "enum": [
        "accepted",
        "missing",
        "rejected",
        "needs_review"
      ]
    }
  }
}
