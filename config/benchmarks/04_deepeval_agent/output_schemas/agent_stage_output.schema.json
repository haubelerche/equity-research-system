{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentStageOutputV3",
  "type": "object",
  "required": [
    "role",
    "ticker",
    "run_id",
    "input_artifact_refs",
    "output_artifact_refs",
    "claims",
    "tool_calls",
    "decision"
  ],
  "properties": {
    "role": {
      "enum": [
        "financial_analysis",
        "forecast_valuation",
        "thesis_report",
        "senior_critic",
        "data_evidence",
        "research_manager"
      ]
    },
    "ticker": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "input_artifact_refs": {
      "type": "array"
    },
    "output_artifact_refs": {
      "type": "array"
    },
    "claims": {
      "type": "array"
    },
    "tool_calls": {
      "type": "array"
    },
    "decision": {
      "type": "string"
    }
  }
}