{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentMessage",
  "type": "object",
  "properties": {
    "run_id": { "type": "string" },
    "step_id": { "type": "string" },
    "agent_role": {
      "type": "string",
      "enum": ["Supervisor", "DataAgent", "QuantAgent", "ResearcherAgent", "AuditorAgent"]
    },
    "objective": { "type": "string" },
    "inputs_ref": {
      "type": "array",
      "items": { "type": "string" }
    },
    "outputs_ref": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "confidence_breakdown": { "type": "object" },
    "evidence_refs": {
      "type": "array",
      "items": { "type": "object" }
    },
    "next_action": { "type": "string" },
    "requires_human": { "type": "boolean" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": [
    "run_id",
    "step_id",
    "agent_role",
    "objective",
    "confidence",
    "confidence_breakdown",
    "evidence_refs",
    "next_action",
    "requires_human",
    "created_at"
  ],
  "additionalProperties": false
}

