{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maer.local/schemas/financial_fact.schema.json",
  "title": "FinancialFact",
  "type": "object",
  "required": [
    "ticker",
    "fiscal_year",
    "fiscal_period",
    "line_item_code",
    "value",
    "unit",
    "currency",
    "source_id",
    "connector_version",
    "validation_status",
    "confidence",
    "ingested_at"
  ],
  "properties": {
    "ticker": { "type": "string", "minLength": 2, "maxLength": 10 },
    "fiscal_year": { "type": "integer", "minimum": 2000, "maximum": 2100 },
    "fiscal_period": { "type": "string", "enum": ["FY", "Q1", "Q2", "Q3", "Q4"] },
    "line_item_code": { "type": "string", "pattern": "^[a-z0-9_.]+$" },
    "value": { "type": "number" },
    "unit": { "type": "string", "enum": ["vnd", "vnd_bn", "ratio", "percent", "shares"] },
    "currency": { "type": "string", "enum": ["VND"] },
    "source_id": { "type": "string", "minLength": 1 },
    "source_uri": { "type": ["string", "null"] },
    "connector_version": { "type": "string", "minLength": 1 },
    "validation_status": {
      "type": "string",
      "enum": ["accepted", "accepted_with_warning", "needs_review", "rejected"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "effective_date": { "type": ["string", "null"] },
    "ingested_at": { "type": "string" }
  },
  "additionalProperties": false
}
