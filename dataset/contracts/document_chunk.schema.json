{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maer.local/schemas/document_chunk.schema.json",
  "title": "DocumentChunk",
  "type": "object",
  "required": [
    "chunk_id",
    "source_version_id",
    "chunk_type",
    "content",
    "content_hash",
    "embedding_model",
    "ingested_at"
  ],
  "properties": {
    "chunk_id": { "type": "string", "minLength": 1 },
    "source_version_id": { "type": "string", "minLength": 1 },
    "chunk_type": { "type": "string", "enum": ["section", "table", "note", "regulatory_clause"] },
    "page": { "type": ["integer", "null"], "minimum": 1 },
    "section_name": { "type": ["string", "null"] },
    "table_id": { "type": ["string", "null"] },
    "content": { "type": "string", "minLength": 1 },
    "content_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "embedding_model": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "enum": ["vi", "en"] },
    "ingested_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
