# ── Vietnam Pharma Equity Research — Environment Template ─────────────────────
# Copy this file to .env.local (for docker-compose) or .env (for local dev).
# NEVER commit .env or .env.local — they contain real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# For local docker-compose dev, docker-compose.yml overrides this with the
# local postgres service. For production, set this to your Supabase pooler URL.
DATABASE_URL=postgresql://maer:maer_local@localhost:5432/maer_dev

# ── LLM API keys ──────────────────────────────────────────────────────────────
# Used by the report generation and research agent steps.
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# ── Default model for report generation ───────────────────────────────────────
DEFAULT_MODEL=gpt-4o-mini

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Supabase (production only) ────────────────────────────────────────────────
# Leave blank for local docker-compose dev.
SUPABASE_PROJECT_ID=
SUPABASE_PUBLIC_KEY=
SUPABASE_SECRET_KEY=

# ── Observability (optional) ──────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
