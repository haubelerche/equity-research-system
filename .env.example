# ── Vietnam Pharma Equity Research — Environment Template ─────────────────────
# Copy this file to .env.local (for docker-compose) or .env (for local dev).
# NEVER commit .env or .env.local — they contain real secrets.

# ── Database ──────────────────────────────────────────────────────────────────
# Required for every runtime. Use the Supabase SESSION-pooler URL (port 5432).
# The long-running research pipeline holds DB connections across several minutes;
# the transaction pooler (port 6543) recycles long-lived connections and causes
# "server closed the connection unexpectedly" mid-run. Use port 5432 (session pooler).
DATABASE_URL=postgresql://postgres.your-project:your-password@aws-0-your-region.pooler.supabase.com:5432/postgres

# ── LLM API keys ──────────────────────────────────────────────────────────────
# Used by the report generation and research agent steps.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY is only needed for the optional chunk_pipeline.py embedding step.
OPENAI_API_KEY=sk-...

# ── Production models ─────────────────────────────────────────────────────────
# Only gpt-5.4-mini and gpt-5.4-nano are allowed in production.
# gpt-5-mini: reasoning, report writing, critic, financial narrative.
# gpt-5-nano: lightweight tasks (route, classify, extract_json, detect_*).
DEFAULT_MODEL_NAME=gpt-5-mini
FALLBACK_MODEL=gpt-5-nano

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Supabase API and Storage ──────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PROJECT_ID=your-project-id
SUPABASE_PUBLIC_KEY=eyJhbGciOi...
SUPABASE_SECRET_KEY=eyJhbGciOi...
# Backend only. Never expose this value to browsers or mobile clients.
SUPABASE_SERVICE_ROLE_KEY=

# ── Observability (optional) ──────────────────────────────────────────────────
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=https://jp.cloud.langfuse.com
